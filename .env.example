# Get a free key at https://aistudio.google.com/apikey
# One key, or several comma-separated keys (the free tier allows ~20
# requests/day per project per model; the client rotates models/keys).
GEMINI_API_KEYS=your_key_here

# Optional overrides
# GENERATION_MODELS=gemini-3.5-flash,gemini-3-flash-preview,gemini-3.1-flash-lite
# EMBEDDING_MODEL=gemini-embedding-001
# NUM_CONTRACTS=50
# REQUESTS_PER_MINUTE=9
